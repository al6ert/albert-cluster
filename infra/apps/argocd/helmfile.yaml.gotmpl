environments:
  minikube: {}
  netcup: {}

---
repositories:
  - name: argo
    url: https://argoproj.github.io/argo-helm

releases:
  - name: argocd
    chart: argo/argo-cd
    version: {{ env "ARGOCD_CHART_VERSION" }}
    namespace: argocd
    values:
      - values.yaml  # Valores base (server insecure, CRDs off, dex off)
      - values-helmfile.yaml.gotmpl  # Configuración para Helmfile plugin
      - ../../envs/{{ .Environment.Name }}/argocd-values.yaml
