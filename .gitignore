.DS_Store
.env
.env.*
!.env.local.example
.cursor
# Kubernetes artefacts que NO quieres subir (ej. secrets)
*.enc.yaml
*-secret.yaml
.certs

# Archivos de credenciales y secretos
tmp/
*.htpasswd
*.key
*.pem
.config/sops/age/keys.txt
.secrets/*.key
.secrets/*.pem

# Manifiestos YAML renderizados (se generan automáticamente)
infra/rendered/**
**/all.yaml

# Temporary files and build artifacts
tmp/**
.tmp/
*.tmp
infra/tmp/

.dev-ci-logs
.ci-logs
