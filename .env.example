# Copia este fichero a .env y rellénalo. .env NO se versiona;
# este .example sí, y es el esquema canónico de las variables que consume
# scripts/generate-credentials.sh.
#
# UN solo fichero para minikube Y netcup: el cluster destino lo elige el
# contexto de kubectl al sellar (los SealedSecrets van atados a su cluster),
# no este fichero. Sin una variable, su componente genera un valor aleatorio
# (salvo los tokens externos, que son obligatorios donde se indica).

# --- basic-auth: login del dashboard de Traefik ---
TRAEFIK_LOGIN=admin
TRAEFIK_PASSWORD=changeme

# --- cloudflare: DNS-01 de cert-manager (OBLIGATORIO para prod) ---
CLOUDFLARE_API_TOKEN=

# --- grafana: admin de kube-prometheus-stack (minikube) ---
GRAFANA_ADMIN_PASSWORD=

# --- grafana-cloud: app monitoring (solo si MONITORING_ENABLED=true) ---
GRAFANA_CLOUD_PROM_USER=
GRAFANA_CLOUD_LOKI_USER=
GRAFANA_CLOUD_TOKEN=

# --- velero: backups a R2 (solo si VELERO_ENABLED=true) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- langfuse: secretos del stack (solo si LANGFUSE_ENABLED=true en prod) ---
# Todas opcionales: vacías se generan aleatorias al sellar. Ninguna requiere
# cuenta externa; son internas al cluster (no las necesitas para hacer login,
# el usuario se crea en la web en la primera visita).
# ⚠️ SALT y ENCRYPTION_KEY cifran los datos ya escritos: generarlas UNA vez
# y no cambiarlas nunca con datos existentes (romperías lo cifrado).
LANGFUSE_SALT=
# Exactamente 64 caracteres hex: openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_POSTGRES_PASSWORD=
LANGFUSE_CLICKHOUSE_PASSWORD=
LANGFUSE_REDIS_PASSWORD=
LANGFUSE_S3_ROOT_PASSWORD=
