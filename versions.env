# versions.env
# Fuente ÚNICA de verdad de versiones (charts y herramientas).
# - Scripts y workflows hacen `source versions.env`.
# - El plugin helmfile de ArgoCD también la lee (source en el comando generate),
#   así que lo que hay aquí es lo que se despliega, en local Y en producción.
# - Las líneas "# renovate:" permiten a Renovate proponer PRs de actualización
#   (reglas en renovate.json5: nada con <7 días, majors manuales).

# Tool Versions
# renovate: datasource=github-releases depName=helm/helm
export HELM_VERSION="v3.21.1"
# renovate: datasource=github-releases depName=helmfile/helmfile
export HELMFILE_VERSION="v1.5.3"
# renovate: datasource=github-releases depName=mikefarah/yq
export YQ_VERSION="v4.53.3"
# Alineadas entre sí y con la versión de Kubernetes de Minikube en CI
# renovate: datasource=github-releases depName=kubernetes/kubernetes
export KUBECTL_VERSION="v1.33.1"
# renovate: datasource=github-releases depName=kubernetes/kubernetes
export KUBERNETES_VERSION="v1.33.1"
# Debe corresponder con el controller del chart sealed-secrets
# renovate: datasource=github-releases depName=bitnami/sealed-secrets
export KUBESEAL_VERSION="v0.37.0"
# CLI de ArgoCD; debe coincidir en minor con el appVersion del chart de argo-cd
# renovate: datasource=github-releases depName=argoproj/argo-cd
export ARGOCD_VERSION="v3.4.3"

# Chart Versions
# renovate: datasource=helm depName=traefik registryUrl=https://traefik.github.io/charts
export TRAEFIK_CHART_VERSION="40.3.0"
# renovate: datasource=helm depName=cert-manager registryUrl=https://charts.jetstack.io
export CERT_MANAGER_CHART_VERSION="v1.20.2"
# renovate: datasource=helm depName=sealed-secrets registryUrl=https://bitnami.github.io/sealed-secrets
export SEALED_SECRETS_CHART_VERSION="2.18.6"
# renovate: datasource=helm depName=argo-cd registryUrl=https://argoproj.github.io/argo-helm
export ARGOCD_CHART_VERSION="9.5.21"
# renovate: datasource=helm depName=kube-prometheus-stack registryUrl=https://prometheus-community.github.io/helm-charts
export PROMETHEUS_CHART_VERSION="86.2.2"
# renovate: datasource=helm depName=k8s-monitoring registryUrl=https://grafana.github.io/helm-charts
export K8S_MONITORING_CHART_VERSION="4.1.6"
# renovate: datasource=helm depName=velero registryUrl=https://vmware-tanzu.github.io/helm-charts
export VELERO_CHART_VERSION="12.1.0"
# renovate: datasource=helm depName=raw registryUrl=https://bedag.github.io/helm-charts
export RAW_CHART_VERSION="2.0.2"

# renovate: datasource=helm depName=localpv-provisioner registryUrl=https://openebs.github.io/dynamic-localpv-provisioner
export STORAGE_CHART_VERSION="4.5.1"

# renovate: datasource=helm depName=langfuse registryUrl=https://langfuse.github.io/langfuse-k8s
export LANGFUSE_CHART_VERSION="1.5.36"

# Image versions — van ligadas al appVersion del chart correspondiente:
# actualizar A LA VEZ que el chart (sin anotación renovate a propósito)
export TRAEFIK_IMAGE_VERSION="v3.7.4"
export CERT_MANAGER_IMAGE_VERSION="v1.20.2"
export VELERO_AWS_PLUGIN_VERSION="v1.13.1"

# CRD bundle versions (infra/bootstrap/crds/) — debe ser la versión de
# Gateway API que soporta la versión de Traefik desplegada (ver su go.mod)
export GATEWAY_API_VERSION="v1.5.1"

# Application Versions (chart local, se versiona a mano)
export HELLO_CHART_VERSION="0.3.0"

# Feature flags de apps solo-prod: en "false" la release no se instala aunque
# el entorno sea netcup. Poner a "true" cuando exista la configuración externa:
# - MONITORING_ENABLED: cuenta Grafana Cloud + URLs reales + secret sellado (docs/observability.md)
# - VELERO_ENABLED: bucket R2 + token S3 + secret sellado (docs/runbooks/disaster-recovery.md)
export MONITORING_ENABLED="false"
export VELERO_ENABLED="false"
# - PROMETHEUS_ENABLED solo afecta a netcup (en minikube siempre se instala:
#   lo valida dev-ci). Verificado 2026-07-03: prod NUNCA lo llegó a desplegar;
#   se mantiene apagado ahí hasta decidir 3b (retirada definitiva).
export PROMETHEUS_ENABLED="false"
# - LANGFUSE_ENABLED solo afecta a netcup (en minikube/CI siempre se instala,
#   con secreto generado al vuelo). Poner a true tras sellar langfuse-secrets
#   contra prod: ./scripts/generate-credentials.sh --component langfuse con
#   contexto kubectl netcup + commit + kubectl apply del sealed.
export LANGFUSE_ENABLED="true"

# GitHub Action Versions
export CHECKOUT_ACTION_VERSION="v4"
export SETUP_KUBECTL_VERSION="v4"
export SETUP_HELM_VERSION="v4"
export HELMFILE_ACTION_VERSION="v2.0.4"
export CACHE_ACTION_VERSION="v4"
export MINIKUBE_ACTION_VERSION="v0.0.15"
